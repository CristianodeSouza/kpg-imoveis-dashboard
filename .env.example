# SIGA CRM (já configurado)
SIGA_TOKEN=83mXBavPZeoPqOSAnJbhAUKvqrcUJVLvF8UHL5eLA

# Instagram Graph API
# Obtenha em: https://developers.facebook.com
INSTAGRAM_ACCESS_TOKEN=SEU_TOKEN_AQUI
INSTAGRAM_ACCOUNT_ID=SEU_ACCOUNT_ID_AQUI

# ImgBB — Hospedagem de imagens (gratuito)
# Cadastro: https://imgbb.com/login → API → My API
